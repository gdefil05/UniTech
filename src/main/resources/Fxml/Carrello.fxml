<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<ScrollPane fitToWidth="true" style="-fx-background-color: #C4DEFF;" stylesheets="@../Style/unitech.css" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="Controller.CarrelloController">

    <content>

        <VBox spacing="20" style="-fx-padding: 30; -fx-background-color: #C4DEFF;">

            <!-- TITOLO -->
            <Label style="-fx-font-size: 28px; -fx-font-weight: bold;" text="Il tuo carrello" />

            <!-- CARRELLO VUOTO -->
            <Label fx:id="lblCarrelloVuoto" style="-fx-font-size: 18px; -fx-text-fill: gray;" text="Carrello vuoto" />

            <!-- PRODOTTI -->
            <VBox fx:id="boxProdotti" spacing="15" />

            <!-- LINEA -->
            <Separator />

            <Button onAction="#esciDalCarrello" style="-fx-background-color: transparent;                     -fx-text-fill: #007aff;                     -fx-font-size: 16;                     -fx-font-weight: bold;                     -fx-cursor: hand;" text="← Esci dal carrello" />

            <!-- TOTALE + CHECKOUT -->
            <VBox alignment="CENTER_RIGHT" spacing="15" style="-fx-padding: 15;">

                <HBox alignment="CENTER_RIGHT" spacing="10">
                    <children>
                        <Label style="-fx-font-size: 18;" text="Totale carrello:" />

                        <Label fx:id="lblTotale" style="-fx-font-size: 18; -fx-font-weight: bold;" text="€ 0.00" />
                    </children>
                </HBox>

                <Button fx:id="btnCheckout" managed="false" mnemonicParsing="false" onAction="#vaiAlCheckout" prefHeight="42.0" prefWidth="200.0" style="-fx-font-weight: bold;" styleClass="accent" text="Vai al Checkout" visible="false" />

            </VBox>

        </VBox>

    </content>
</ScrollPane>
